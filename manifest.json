{
  "manifest_version": 3,
  "name": "Threat Blocker",
  "version": "1.0.0",
  "description": "Block malicious domains and phishing sites using real-time threat intelligence",
  "permissions": [
    "tabs",
    "webRequest",
    "storage"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Threat Blocker"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
