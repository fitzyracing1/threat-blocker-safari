{
  "manifest_version": 3,
  "name": "Threat Blocker",
  "version": "1.0.0",
  "description": "Real-time threat blocking using multiple threat intelligence feeds",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_title": "Threat Blocker"
  },
  "permissions": [
    "storage",
    "tabs",
    "webRequest",
    "webNavigation",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "options_page": "settings.html",
  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "history.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
